{
  "$schema": "https://opencode.ai/config.json",
  "lsp": {
    "rust-analyzer": {
      "command": ["rust-analyzer"],
      "extensions": [".rs"],
      "initialization": {
        "check": {
          "command": "clippy",
          "extraArgs": ["--all-targets"]
        },
        "procMacro": {
          "enable": true
        }
      }
    }
  }
}
