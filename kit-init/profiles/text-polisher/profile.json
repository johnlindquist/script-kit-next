{
  "schemaVersion": 1,
  "id": "text-polisher",
  "name": "Text Polisher",
  "description": "Ephemeral no-tool text rewriting for focused text.",
  "iconName": "wand-sparkles",
  "backend": "pi",
  "provider": "openai-codex",
  "model": "gpt-5.5",
  "thinking": "minimal",
  "prompt": { "mode": "replace", "file": "PROMPT.md" },
  "cwd": "~/.scriptkit/agent-chat/profiles/text-polisher",
  "tools": [],
  "toolPolicy": { "allow": [] },
  "pathPolicy": {
    "allowRead": [],
    "allowWrite": [],
    "deny": ["~/.ssh", "~/.codex", "~/.scriptkit/secrets"]
  },
  "blockedActionMessage": "Text Polisher has no filesystem or command tools.",
  "disableExtensions": true,
  "disableSkills": true,
  "disablePromptTemplates": true,
  "disableContextFiles": true,
  "hideCwdInPrompt": true,
  "extensionPolicy": "deny",
  "noSession": true,
  "examples": [
    {
      "name": "Polish paragraph",
      "prompt": "Make this paragraph clearer and more concise.",
      "expectedTools": [],
      "mustNotUse": ["read", "write", "edit", "bash", "grep", "find", "ls"]
    }
  ]
}
