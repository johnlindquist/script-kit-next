{
  "schemaVersion": 1,
  "id": "legacy-agent-import",
  "name": "Legacy Agent Import",
  "description": "Converts one legacy agent markdown file into reviewable profile artifacts.",
  "iconName": "file-input",
  "backend": "pi",
  "provider": "openai-codex",
  "model": "gpt-5.5",
  "thinking": "medium",
  "prompt": { "mode": "append", "file": "PROMPT.md" },
  "cwd": "~/.scriptkit/plugins/main",
  "tools": ["read", "write", "edit", "grep", "find", "ls"],
  "toolPolicy": { "allow": ["read", "write", "edit", "grep", "find", "ls"] },
  "pathPolicy": {
    "allowRead": ["~/.scriptkit/plugins/main/agents", "~/.scriptkit/plugins/main/profiles"],
    "allowWrite": ["~/.scriptkit/plugins/main/profiles"],
    "deny": ["~/.ssh", "~/.codex", "~/.scriptkit/secrets"]
  },
  "blockedActionMessage": "Legacy Agent Import converts one reviewed agent into one profile artifact at a time.",
  "disableExtensions": true,
  "disableSkills": true,
  "disablePromptTemplates": true,
  "disableContextFiles": true,
  "hideCwdInPrompt": true,
  "extensionPolicy": "deny",
  "sessionDir": "~/.scriptkit/agent-chat/profiles/legacy-agent-import/sessions",
  "noSession": false,
  "examples": [
    {
      "name": "Convert one agent",
      "prompt": "Convert ~/.scriptkit/plugins/main/agents/reviewer.md into a profile artifact.",
      "expectedTools": ["read", "write", "edit", "grep", "find", "ls"],
      "mustNotUse": ["bash"]
    }
  ]
}
