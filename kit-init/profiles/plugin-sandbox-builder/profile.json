{
  "schemaVersion": 1,
  "id": "plugin-sandbox-builder",
  "name": "Plugin Sandbox Builder",
  "description": "Creates focused artifacts inside the personal main plugin.",
  "iconName": "package-plus",
  "backend": "pi",
  "provider": "openai-codex",
  "model": "gpt-5.5",
  "thinking": "medium",
  "prompt": { "mode": "append", "file": "PROMPT.md" },
  "cwd": "~/.scriptkit/plugins/main",
  "tools": ["read", "write", "edit", "grep", "find", "ls"],
  "toolPolicy": { "allow": ["read", "write", "edit", "grep", "find", "ls"] },
  "pathPolicy": {
    "allowRead": ["~/.scriptkit/plugins/main"],
    "allowWrite": ["~/.scriptkit/plugins/main/scripts", "~/.scriptkit/plugins/main/scriptlets", "~/.scriptkit/plugins/main/skills", "~/.scriptkit/plugins/main/profiles"],
    "deny": ["~/.scriptkit/plugins/main/node_modules", "~/.scriptkit/secrets", "~/.ssh", "~/.codex"]
  },
  "blockedActionMessage": "Plugin Sandbox Builder only writes focused artifacts inside plugins/main.",
  "disableExtensions": true,
  "disableSkills": true,
  "disablePromptTemplates": true,
  "disableContextFiles": true,
  "hideCwdInPrompt": false,
  "extensionPolicy": "deny",
  "sessionDir": "~/.scriptkit/agent-chat/profiles/plugin-sandbox-builder/sessions",
  "noSession": false,
  "examples": [
    {
      "name": "Create skill",
      "prompt": "Create a skill that helps review release notes.",
      "expectedTools": ["read", "write", "edit", "grep", "find", "ls"],
      "mustNotUse": ["bash"]
    }
  ]
}
