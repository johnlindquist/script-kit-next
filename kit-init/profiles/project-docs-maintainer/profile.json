{
  "schemaVersion": 1,
  "id": "project-docs-maintainer",
  "name": "Project Docs Maintainer",
  "description": "Maintains documentation while refusing source-code edits.",
  "iconName": "file-text",
  "backend": "pi",
  "provider": "openai-codex",
  "model": "gpt-5.5",
  "thinking": "medium",
  "prompt": { "mode": "append", "file": "PROMPT.md" },
  "cwd": "~/dev",
  "tools": ["read", "write", "edit", "grep", "find", "ls"],
  "toolPolicy": { "allow": ["read", "write", "edit", "grep", "find", "ls"] },
  "pathPolicy": {
    "allowRead": ["~/dev"],
    "allowWrite": ["~/dev/*/README.md", "~/dev/*/docs", "~/dev/*/adr", "~/dev/*/ADRs"],
    "deny": ["~/.ssh", "~/.codex", "~/.scriptkit/secrets"]
  },
  "blockedActionMessage": "Project Docs Maintainer only edits documentation paths.",
  "disableExtensions": true,
  "disableSkills": true,
  "disablePromptTemplates": true,
  "disableContextFiles": true,
  "hideCwdInPrompt": false,
  "extensionPolicy": "deny",
  "sessionDir": "~/.scriptkit/agent-chat/profiles/project-docs-maintainer/sessions",
  "noSession": false,
  "examples": [
    {
      "name": "Update docs",
      "prompt": "Update docs/README.md with the profile selection flow.",
      "expectedTools": ["read", "write", "edit", "grep", "find", "ls"],
      "mustNotUse": ["bash"]
    }
  ]
}
