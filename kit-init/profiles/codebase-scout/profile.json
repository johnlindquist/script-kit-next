{
  "schemaVersion": 1,
  "id": "codebase-scout",
  "name": "Codebase Scout",
  "description": "Read-only local codebase inspection with source citations.",
  "iconName": "search",
  "backend": "pi",
  "provider": "openai-codex",
  "model": "gpt-5.5",
  "thinking": "low",
  "prompt": { "mode": "append", "file": "PROMPT.md" },
  "cwd": "~/.scriptkit/agent-chat/profiles/codebase-scout",
  "tools": ["read", "grep", "find", "ls"],
  "toolPolicy": { "allow": ["read", "grep", "find", "ls"] },
  "pathPolicy": {
    "allowRead": ["~/dev"],
    "allowWrite": [],
    "deny": ["~/.ssh", "~/.codex", "~/.scriptkit/secrets"]
  },
  "blockedActionMessage": "Codebase Scout is read-only.",
  "disableExtensions": true,
  "disableSkills": true,
  "disablePromptTemplates": true,
  "disableContextFiles": true,
  "hideCwdInPrompt": true,
  "extensionPolicy": "deny",
  "noSession": true,
  "examples": [
    {
      "name": "Find owner",
      "prompt": "Find the files that own Agent Chat profile selection and summarize them.",
      "expectedTools": ["read", "grep", "find", "ls"],
      "mustNotUse": ["write", "edit", "bash"]
    }
  ]
}
