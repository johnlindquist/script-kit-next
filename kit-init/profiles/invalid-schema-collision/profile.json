{
  "schemaVersion": 1,
  "id": "invalid-schema-collision",
  "name": "Invalid Schema Collision",
  "description": "Creates negative fixtures that prove unsafe profile artifacts fail closed.",
  "iconName": "shield-alert",
  "backend": "pi",
  "provider": "openai-codex",
  "model": "gpt-5.5",
  "thinking": "low",
  "prompt": { "mode": "append", "file": "PROMPT.md" },
  "cwd": "~/.scriptkit/plugins/main/profiles",
  "tools": ["read", "write", "edit", "grep", "find", "ls"],
  "toolPolicy": { "allow": ["read", "write", "edit", "grep", "find", "ls"] },
  "pathPolicy": {
    "allowRead": ["~/.scriptkit/plugins/main/profiles"],
    "allowWrite": ["~/.scriptkit/plugins/main/profiles"],
    "deny": ["~/.ssh", "~/.codex", "~/.scriptkit/secrets"]
  },
  "blockedActionMessage": "Invalid Schema Collision can only create reviewed negative profile fixtures under profiles.",
  "disableExtensions": true,
  "disableSkills": true,
  "disablePromptTemplates": true,
  "disableContextFiles": true,
  "hideCwdInPrompt": true,
  "extensionPolicy": "deny",
  "sessionDir": "~/.scriptkit/agent-chat/profiles/invalid-schema-collision/sessions",
  "noSession": false,
  "examples": [
    {
      "name": "Create invalid fixture",
      "prompt": "Create an invalid profile fixture with id script-kit and explain the expected validation failure.",
      "expectedTools": ["read", "write", "edit", "grep", "find", "ls"],
      "mustNotUse": ["bash"]
    }
  ]
}
