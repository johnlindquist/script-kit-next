{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bun .codex/hooks/block-git-stash.ts",
            "statusMessage": "Checking for blocked git stash commands"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun \"$(git rev-parse --show-toplevel)/.codex/hooks/stop-continue-agentic-testing.ts\"",
            "timeout": 30,
            "statusMessage": "Checking scoped Stop continuation"
          }
        ]
      }
    ]
  }
}
