{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "kit://schema/menu-syntax/payload-v1",
  "title": "Menu Syntax Payload v1",
  "description": "Structured payload written to KIT_MENU_SYNTAX_PAYLOAD_PATH when a menu-syntax capture handler is executed.",
  "type": "object",
  "required": ["version", "family", "target", "raw", "body", "tags", "dates", "handler"],
  "additionalProperties": false,
  "properties": {
    "version": { "const": "menu-syntax.payload.v1" },
    "family": { "type": "string", "enum": ["capture.v1"] },
    "target": { "type": "string", "enum": ["todo", "cal", "note", "social", "link"] },
    "raw": { "type": "string" },
    "body": { "type": "string" },
    "tags": { "type": "array", "items": { "type": "string" } },
    "priority": {
      "type": ["integer", "null"],
      "minimum": 1,
      "maximum": 4
    },
    "url": { "type": ["string", "null"] },
    "duration": { "type": ["string", "null"] },
    "kv": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "dates": {
      "type": "array",
      "items": { "$ref": "#/$defs/resolvedDate" }
    },
    "handler": {
      "type": "object",
      "required": ["kind", "commandId", "name"],
      "additionalProperties": false,
      "properties": {
        "kind": { "type": "string", "enum": ["script", "scriptlet"] },
        "commandId": { "type": "string" },
        "name": { "type": "string" },
        "pluginId": { "type": ["string", "null"] }
      }
    }
  },
  "$defs": {
    "resolvedDate": {
      "type": "object",
      "required": ["role", "source", "sourceSpan", "iso", "relative", "timezone", "allDay", "granularity", "confidence"],
      "additionalProperties": false,
      "properties": {
        "role": { "type": "string", "enum": ["due", "at", "start", "end", "inferred"] },
        "source": { "type": "string" },
        "sourceSpan": {
          "type": "array",
          "prefixItems": [{ "type": "integer" }, { "type": "integer" }],
          "items": false,
          "minItems": 2,
          "maxItems": 2
        },
        "iso": { "type": "string" },
        "relative": { "type": "string" },
        "timezone": { "type": "string" },
        "allDay": { "type": "boolean" },
        "granularity": { "type": "string", "enum": ["date", "minute", "second"] },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    }
  }
}
